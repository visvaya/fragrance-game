{
  "name": "eauxle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "lint": "pnpm lint:strict",
    "lint:report": "node scripts/lint-report.js",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:report": "tsc --noEmit > reports/typecheck.log 2>&1",
    "knip:report": "knip --reporter json --no-exit-code > reports/knip.json 2>&1",
    "depcheck:report": "depcheck --json > reports/depcheck.json 2>&1",
    "quality:report": "node scripts/quality.js",
    "quality:report:no-tests": "node scripts/quality.js --no-tests",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:dev": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y",
    "test:load": "artillery run scripts/load-test.yaml",
    "test:perf": "playwright test e2e/performance",
    "test:full": "pnpm test && pnpm test:a11y && pnpm test:perf",
    "audit:report": "node scripts/audit-parse.js",
    "audit:lighthouse": "python ../.agent/scripts/parse_lighthouse.py ./reports/latest.report.json",
    "clean": "pnpm dlx rimraf .next node_modules",
    "supabase": "pnpm dlx supabase",
    "supabase:types": "pnpm dlx tsx scripts/gen-supabase-types.ts",
    "supabase:advisors": "pnpm supabase db lint --linked",
    "generate:zod": "pnpm dlx tsx scripts/generate-zod.ts --input types/supabase.ts --output lib/validations/supabase.schema.ts",
    "audit:react": "npx -y react-doctor@latest . --verbose --offline --no-ami --yes"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@marsidev/react-turnstile": "^1.4.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/nextjs": "^10.35.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@types/ua-parser-js": "^0.7.39",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/analytics": "^1.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lenis": "^1.3.17",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.331.0",
    "posthog-node": "^5.21.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.60.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "ua-parser-js": "^2.0.9",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/compat": "^1.3.1",
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@whoisarpit/supabase-to-zod": "^1.0.1",
    "artillery": "^2.0.30",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsdoc": "^62.5.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-playwright": "^2.5.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "knip": "^5.84.1",
    "postcss": "^8.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "supabase": "^2.76.8",
    "tailwindcss": "^4.1.9",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.17"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@opentelemetry/api"
      ],
      "allowAny": [
        "@opentelemetry/api"
      ]
    }
  }
}